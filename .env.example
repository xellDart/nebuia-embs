# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost/pdf_embeddings

# ─── S3 / MinIO ────────────────────────────────────────
MINIO_ENDPOINT=s3.example.com
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET=documents

# ─── Model ──────────────────────────────────────────────
MODEL_PATH=/path/to/Ops-Colqwen3-4B
MODEL_DEVICE=cuda           # cuda | cpu
MODEL_BATCH_SIZE=9          # images per batch (reduce if OOM)
MODEL_DTYPE=bfloat16        # bfloat16 | float32
MODEL_DIMS=1280             # embedding dims (1280 or 2560, Matryoshka)

# ─── Cache ──────────────────────────────────────────────
CACHE_MAX_SIZE=10           # max documents in LRU cache
CACHE_EXPIRY_HOURS=24       # TTL for cached embeddings

# ─── NATS (optional) ───────────────────────────────────
NATS_URL=nats://localhost:4222
NATS_ENABLED=false          # true to enable JetStream consumer

# ─── Server ────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
MAX_RETRIES=5
RETRY_DELAY=3
